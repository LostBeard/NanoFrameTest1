<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- Single worker: avoids testhost locking NanoFrameTest1.Tests.dll during parallel builds/runs. -->
  <RunConfiguration>
    <MaxCpuCount>1</MaxCpuCount>
  </RunConfiguration>
  <NUnit>
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
  </NUnit>
</RunSettings>
