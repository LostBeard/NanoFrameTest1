@page "/"
@implements IAsyncDisposable

<PageTitle>ESP32-S3 Dashboard</PageTitle>

<h1>ESP32-S3-WROOM Dashboard</h1>

@if (!_bleService.IsWebBluetoothSupported)
{
    <div class="alert alert-danger">Web Bluetooth is not supported in this browser. Use Chrome or Edge.</div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" disabled="@_bleService.IsConnected" @onclick="ConnectAsync">
            Connect to ESP32
        </button>
        <button class="btn btn-outline-secondary" disabled="@(!_bleService.IsConnected)" @onclick="DisconnectAsync">
            Disconnect
        </button>
    </div>

    <div class="alert @(_bleService.IsConnected ? "alert-success" : "alert-secondary")">
        <strong>BLE:</strong> @(_bleService.IsConnected ? $"Connected to {_bleService.DeviceName}" : "Disconnected")
    </div>

    @if (_bleService.IsConnected && _bleService.IsGattReady)
    {
        <div class="card mb-3">
            <div class="card-header"><strong>WiFi Configuration</strong></div>
            <div class="card-body">
                <div class="alert @WifiStatusAlertClass mb-3">
                    <strong>Status:</strong> @_wifiStatus.State
                    @if (!string.IsNullOrEmpty(_wifiStatus.IpAddress))
                    {
                        <span class="ms-2">IP: @_wifiStatus.IpAddress</span>
                    }
                </div>

                <div class="mb-3">
                    <button class="btn btn-outline-primary me-2" disabled="@_scanning" @onclick="ScanWifiAsync">
                        @(_scanning ? "Scanning…" : "Scan networks")
                    </button>
                    <button class="btn btn-outline-warning me-2" @onclick="DisconnectWifiAsync">Disconnect WiFi</button>
                    <button class="btn btn-outline-secondary" @onclick="ForgetWifiAsync">Forget credentials</button>
                </div>

                @if (_networks.Count > 0)
                {
                    <p class="text-muted small mb-2">Tap a network to use its SSID.</p>
                    <ul class="list-group mb-3">
                        @foreach (var n in _networks)
                        {
                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                style="cursor: pointer;"
                                @onclick="() => SelectNetwork(n.Ssid)">
                                <span>@n.Ssid</span>
                                <span class="badge bg-secondary">@n.Rssi dBm (@n.SignalBars bars)</span>
                            </li>
                        }
                    </ul>
                }

                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <label class="form-label">SSID</label>
                        <input class="form-control" @bind="_ssid" placeholder="Network name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input class="form-control" type="password" @bind="_password" placeholder="Password" />
                    </div>
                </div>
                <button class="btn btn-success" @onclick="ConnectWifiAsync">Connect to WiFi</button>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Debug Console</strong></div>
            <div class="card-body">
                <pre class="bg-dark text-light p-3 rounded small" style="max-height: 240px; overflow-y: auto; white-space: pre-wrap;">@_logText</pre>
                <div class="input-group mt-2">
                    <input class="form-control" @bind="_debugCommand" @onkeyup="OnDebugKeyUp" placeholder="Command…" />
                    <button class="btn btn-primary" @onclick="SendDebugAsync">Send</button>
                </div>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mt-2">@_error</div>
}

@code {
    [Inject] BleDeviceService _bleService { get; set; } = default!;
    [Inject] WasmTestDebugHubClient WasmTestDebugHub { get; set; } = default!;

    WifiStatus _wifiStatus = new();
    List<WifiNetwork> _networks = new();
    string _ssid = "";
    string _password = "";
    string _debugCommand = "";
    string _logText = "";
    string _error = "";
    bool _scanning;

    string WifiStatusAlertClass => _wifiStatus.State switch
    {
        WifiConnectionState.Connected => "alert-success",
        WifiConnectionState.Connecting => "alert-warning",
        WifiConnectionState.Failed => "alert-danger",
        _ => "alert-secondary"
    };

    protected override void OnInitialized()
    {
        _bleService.OnConnected += OnBleConnected;
        _bleService.OnDisconnected += OnBleDisconnected;
        _bleService.OnWifiStatusChanged += OnWifiStatusChanged;
        _bleService.OnWifiScanResults += OnWifiScanResults;
        _bleService.OnDebugLog += OnDebugLog;
    }

    void OnBleConnected() => InvokeAsync(StateHasChanged);
    void OnBleDisconnected()
    {
        _networks.Clear();
        _wifiStatus = new WifiStatus();
        InvokeAsync(StateHasChanged);
    }

    void OnWifiStatusChanged(WifiStatus s)
    {
        _wifiStatus = s;
        _scanning = false;
        InvokeAsync(StateHasChanged);
    }

    void OnWifiScanResults(List<WifiNetwork> list)
    {
        _networks = list;
        _scanning = false;
        InvokeAsync(StateHasChanged);
    }

    void OnDebugLog(string line)
    {
        _logText += line + "\n";
        if (_logText.Length > 16000)
            _logText = _logText[^12000..];
        _ = WasmTestDebugHub.LogAsync(line);
        InvokeAsync(StateHasChanged);
    }

    async Task ConnectAsync()
    {
        _error = "";
        _logText = "";
        try
        {
            await _bleService.ConnectAsync();
        }
        catch (Exception ex)
        {
            _error = $"Connection failed: {ex.Message}";
        }
        StateHasChanged();
    }

    async Task DisconnectAsync()
    {
        await _bleService.DisconnectAsync();
        StateHasChanged();
    }

    async Task ScanWifiAsync()
    {
        _scanning = true;
        _error = "";
        try
        {
            await _bleService.ScanWifiNetworks();
        }
        catch (Exception ex)
        {
            _error = $"Scan failed: {ex.Message}";
            _scanning = false;
        }
        StateHasChanged();
    }

    void SelectNetwork(string ssid) => _ssid = ssid;

    async Task ConnectWifiAsync()
    {
        _error = "";
        try
        {
            await _bleService.SendWifiCredentials(_ssid, _password);
            await _bleService.ConnectWifi();
        }
        catch (Exception ex)
        {
            _error = $"WiFi connect failed: {ex.Message}";
        }
        StateHasChanged();
    }

    async Task DisconnectWifiAsync()
    {
        try
        {
            await _bleService.DisconnectWifi();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    async Task ForgetWifiAsync()
    {
        try
        {
            await _bleService.ForgetWifi();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    async Task SendDebugAsync()
    {
        if (string.IsNullOrWhiteSpace(_debugCommand)) return;
        _error = "";
        try
        {
            await _bleService.SendDebugCommand(_debugCommand);
            _debugCommand = "";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    async Task OnDebugKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendDebugAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _bleService.OnConnected -= OnBleConnected;
        _bleService.OnDisconnected -= OnBleDisconnected;
        _bleService.OnWifiStatusChanged -= OnWifiStatusChanged;
        _bleService.OnWifiScanResults -= OnWifiScanResults;
        _bleService.OnDebugLog -= OnDebugLog;
        await ValueTask.CompletedTask;
    }
}
