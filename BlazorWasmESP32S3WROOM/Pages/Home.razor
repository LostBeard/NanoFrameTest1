@page "/"
@using BlazorWasmESP32S3WROOM.Services
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@implements IAsyncDisposable

<PageTitle>ESP32-S3 Dashboard</PageTitle>

<h1>ESP32-S3-WROOM Dashboard</h1>

@if (!_bleService.IsWebBluetoothSupported)
{
    <div class="alert alert-danger">Web Bluetooth is not supported in this browser. Use Chrome or Edge.</div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" disabled="@_bleService.IsConnected" @onclick="ConnectAsync">
            Connect to ESP32
        </button>
        <button class="btn btn-outline-secondary" disabled="@(!_bleService.IsConnected)" @onclick="DisconnectAsync">
            Disconnect
        </button>
    </div>

    <div class="alert @(_bleService.IsConnected ? "alert-success" : "alert-secondary")">
        <strong>BLE:</strong> @(_bleService.IsConnected ? $"Connected to {_bleService.DeviceName}" : "Disconnected")
    </div>

    @if (_bleService.IsConnected)
    {
        <!-- WiFi Status -->
        <div class="card mb-3">
            <div class="card-header"><strong>WiFi Status</strong></div>
            <div class="card-body">
                <p>
                    <strong>State:</strong>
                    <span class="badge @WifiStatusBadgeClass">@_wifiStatus.State</span>
                    @if (!string.IsNullOrEmpty(_wifiStatus.IpAddress))
                    {
                        <span class="ms-2">IP: <code>@_wifiStatus.IpAddress</code></span>
                    }
                </p>
            </div>
        </div>

        <!-- WiFi Configuration -->
        <div class="card mb-3">
            <div class="card-header"><strong>WiFi Configuration</strong></div>
            <div class="card-body">
                <div class="row g-2 mb-2">
                    <div class="col-auto">
                        <button class="btn btn-sm btn-outline-primary" @onclick="ScanWifi" disabled="@_scanning">
                            @(_scanning ? "Scanning..." : "Scan Networks")
                        </button>
                    </div>
                </div>

                @if (_networks.Count > 0)
                {
                    <div class="list-group mb-3">
                        @foreach (var network in _networks)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(network.Ssid == _ssid ? "active" : "")"
                                    @onclick="() => SelectNetwork(network.Ssid)">
                                @network.Ssid
                                <span class="badge bg-secondary">@network.Rssi dBm (@(new string('|', network.SignalBars))@(new string('.', 4 - network.SignalBars)))</span>
                            </button>
                        }
                    </div>
                }

                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">SSID</label>
                        <input type="text" class="form-control" @bind="_ssid" placeholder="Network name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="_password" placeholder="Password" />
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-success" @onclick="ConnectWifi"
                                disabled="@(string.IsNullOrWhiteSpace(_ssid))">
                            Connect WiFi
                        </button>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-warning" @onclick="DisconnectWifi">Disconnect WiFi</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Debug Console -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between">
                <strong>Debug Console</strong>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLog">Clear</button>
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="input-group">
                        <input type="text" class="form-control font-monospace" @bind="_debugCommand"
                               @onkeydown="OnDebugKeyDown" placeholder="Type a command..." />
                        <button class="btn btn-outline-primary" @onclick="SendDebugCommand">Send</button>
                    </div>
                </div>
                <pre class="bg-dark text-light p-2 rounded" style="max-height:300px;overflow-y:auto;font-size:0.85em;">@foreach (var line in _logLines)
{@line
}</pre>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mt-2">@_error</div>
}

@code {
    [Inject] BleDeviceService _bleService { get; set; } = default!;

    WifiStatus _wifiStatus = new();
    List<WifiNetwork> _networks = new();
    List<string> _logLines = new();

    string _ssid = "";
    string _password = "";
    string _debugCommand = "";
    string _error = "";
    bool _scanning;

    protected override void OnInitialized()
    {
        _bleService.OnConnected += OnConnected;
        _bleService.OnDisconnected += OnDisconnected;
        _bleService.OnWifiStatusChanged += OnWifiStatusChanged;
        _bleService.OnWifiScanResults += OnWifiScanResults;
        _bleService.OnDebugLog += OnDebugLog;
    }

    async Task ConnectAsync()
    {
        _error = "";
        try
        {
            await _bleService.ConnectAsync();
        }
        catch (Exception ex)
        {
            _error = $"Connection failed: {ex.Message}";
        }
    }

    async Task DisconnectAsync()
    {
        await _bleService.DisconnectAsync();
        StateHasChanged();
    }

    async Task ScanWifi()
    {
        _scanning = true;
        _error = "";
        try
        {
            await _bleService.ScanWifiNetworks();
        }
        catch (Exception ex)
        {
            _error = $"Scan failed: {ex.Message}";
            _scanning = false;
        }
    }

    void SelectNetwork(string ssid)
    {
        _ssid = ssid;
    }

    async Task ConnectWifi()
    {
        _error = "";
        try
        {
            await _bleService.SendWifiCredentials(_ssid, _password);
            await _bleService.ConnectWifi();
        }
        catch (Exception ex)
        {
            _error = $"WiFi connect failed: {ex.Message}";
        }
    }

    async Task DisconnectWifi()
    {
        try { await _bleService.DisconnectWifi(); }
        catch (Exception ex) { _error = $"WiFi disconnect failed: {ex.Message}"; }
    }

    async Task SendDebugCommand()
    {
        if (string.IsNullOrWhiteSpace(_debugCommand)) return;
        try
        {
            _logLines.Add($"> {_debugCommand}");
            await _bleService.SendDebugCommand(_debugCommand);
            _debugCommand = "";
        }
        catch (Exception ex)
        {
            _error = $"Command failed: {ex.Message}";
        }
    }

    async Task OnDebugKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendDebugCommand();
    }

    void ClearLog() => _logLines.Clear();

    void OnConnected()
    {
        _logLines.Add("[Connected to ESP32]");
        StateHasChanged();
    }

    void OnDisconnected()
    {
        _wifiStatus = new();
        _networks.Clear();
        _logLines.Add("[Disconnected from ESP32]");
        StateHasChanged();
    }

    void OnWifiStatusChanged(WifiStatus status)
    {
        _wifiStatus = status;
        StateHasChanged();
    }

    void OnWifiScanResults(List<WifiNetwork> networks)
    {
        _networks = networks;
        _scanning = false;
        StateHasChanged();
    }

    void OnDebugLog(string message)
    {
        _logLines.Add(message);
        // Keep log from growing unbounded
        while (_logLines.Count > 500)
            _logLines.RemoveAt(0);
        StateHasChanged();
    }

    string WifiStatusBadgeClass => _wifiStatus.State switch
    {
        WifiConnectionState.Connected => "bg-success",
        WifiConnectionState.Connecting => "bg-warning text-dark",
        WifiConnectionState.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    public async ValueTask DisposeAsync()
    {
        _bleService.OnConnected -= OnConnected;
        _bleService.OnDisconnected -= OnDisconnected;
        _bleService.OnWifiStatusChanged -= OnWifiStatusChanged;
        _bleService.OnWifiScanResults -= OnWifiScanResults;
        _bleService.OnDebugLog -= OnDebugLog;
    }
}
